---
import Layout from '@/layouts/Layout.astro'
import { template } from '@/settings'

const cvUrl = `${template.base}/cv.pdf`
---
<Layout title="Jeanne Marlier - CV">
  <div class="max-w-none">
    <div class="flex flex-wrap items-center justify-between gap-2 mb-4">
      <h1 class="text-3xl font-bold">Curriculum Vitae</h1>
      <a href={cvUrl} target="_blank" class="btn btn-sm btn-access text-access-content">
        Download PDF
      </a>
    </div>
<iframe
  src={`${cvUrl}#toolbar=0`}
  class="w-full h-[85vh] rounded border border-base-300"
  title="Curriculum Vitae"
></iframe>
  </div>
</Layout>
